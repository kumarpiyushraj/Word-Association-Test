    <TextView
        android:id="@+id/timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/back4"
        android:fontFamily="@font/open_sans_bold"
        android:textColor="@color/white"
        android:textSize="30dp"
        android:paddingRight="10dp"
        android:paddingLeft="10dp"
        android:textAlignment="center"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <ViewFlipper
        android:id="@+id/viewflipper"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="70sp"
        app:layout_constraintTop_toBottomOf="@id/timer"
        app:layout_constraintBottom_toTopOf="@id/sentence"
        app:layout_constraintLeft_toLeftOf="@id/timer"
        app:layout_constraintRight_toRightOf="@id/timer">
    </ViewFlipper>



    <EditText
        android:id="@+id/sentence"
        android:layout_width="300sp"
        android:layout_height="100sp"
        android:background="@drawable/sentence_back"
        android:padding="10sp"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:hint="Write here..."
        android:layout_marginVertical="80sp"
        android:singleLine="true"
        android:imeOptions="actionDone"
        android:maxLength="60"
        android:textColorHint="@color/black"
        app:layout_constraintTop_toBottomOf="@id/viewflipper"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

<!--    <ImageButton-->
<!--        android:id="@+id/tick"-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:src="@drawable/check_mark"-->
<!--        android:background="@drawable/txtview"-->
<!--        android:foreground="?attr/selectableItemBackground"-->
<!--        app:layout_constraintLeft_toRightOf="@id/sentence"-->
<!--        app:layout_constraintRight_toRightOf="parent"-->
<!--        app:layout_constraintTop_toTopOf="@id/sentence"-->
<!--        app:layout_constraintBottom_toBottomOf="@id/sentence"/>-->

    <TextView
        android:id="@+id/scoreTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Score = 0"
        android:textSize="25sp"
        android:visibility="gone"
        android:fontFamily="@font/open_sans_bold"
        android:textColor="@color/white"
        android:paddingRight="10dp"
        android:paddingLeft="10dp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/sentence"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <Button
        android:id="@+id/restart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Restart"
        android:layout_marginTop="100sp"
        android:padding="10sp"
        android:visibility="gone"
        android:background="@drawable/back2"
        android:foreground="?attr/selectableItemBackground"
        android:fontFamily="@font/open_sans_bold"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/sentence"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>