<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layer1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01235E"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WAT APPLICATION"
        android:shadowColor="@color/text_shadow"
        android:shadowDy="-1"
        android:shadowRadius="2"
        android:background="@drawable/back3"
        android:textSize="34sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:fontFamily="@font/open_sans_bold"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_marginTop="60sp"
        app:layout_constraintLeft_toLeftOf="@id/layer1"
        app:layout_constraintRight_toRightOf="@id/layer1"
        app:layout_constraintTop_toTopOf="@id/layer1"/>

    <ViewFlipper
        android:id="@+id/enterword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@id/layer1"
        app:layout_constraintLeft_toLeftOf="@id/layer1"
        app:layout_constraintRight_toRightOf="@id/layer1"
        app:layout_constraintTop_toTopOf="@id/layer1">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/FirstLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20sp"
            android:layout_gravity="center_vertical|center_horizontal">

            <!--            <EditText-->
            <!--                android:id="@+id/upperLimit"-->
            <!--                android:layout_width="wrap_content"-->
            <!--                android:layout_height="50dp"-->
            <!--                android:padding="10sp"-->
            <!--                android:layout_marginTop="40dp"-->
            <!--                android:layout_marginBottom="10sp"-->
            <!--                android:hint="Enter UpperLimit"-->
            <!--                android:textColor="@color/white"-->
            <!--                android:textColorHint="@color/white"-->
            <!--                android:textSize="17sp"-->
            <!--                android:textStyle="bold"-->
            <!--                android:textAlignment="center"-->
            <!--                android:inputType="number"-->
            <!--                android:maxLength="2"-->
            <!--                android:background="@drawable/edittext_back"-->
            <!--                android:imeOptions="actionDone"-->
            <!--                android:fontFamily="@font/open_sans_bold"-->
            <!--                app:layout_constraintTop_toTopOf="@id/FirstLayout"-->
            <!--                app:layout_constraintLeft_toLeftOf="@id/FirstLayout"-->
            <!--                app:layout_constraintRight_toRightOf="@id/FirstLayout"/>-->

            <TextView
                android:id="@+id/textView1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Word Association Test (WAT) evaluates personality and cognitive ability. The test requires the candidate to write down the first thought that occurs to them after being shown a series of words or a collection of words. This may be answered in a full statement, phrase or combination of words."
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:layout_marginTop="10sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:background="@drawable/txtview"
                android:fontFamily="@font/open_sans_bold"
                app:layout_constraintTop_toTopOf="@id/FirstLayout"
                app:layout_constraintLeft_toLeftOf="@id/FirstLayout"
                app:layout_constraintRight_toRightOf="@id/FirstLayout"
                app:layout_constraintBottom_toBottomOf="@id/FirstLayout"/>

            <Button
                android:id="@+id/start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start"
                android:background="@drawable/back2"
                android:foreground="?attr/selectableItemBackground"
                android:fontFamily="@font/open_sans_bold"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toBottomOf="@id/textView1"
                app:layout_constraintLeft_toLeftOf="@id/textView1"
                app:layout_constraintRight_toRightOf="@id/textView1"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/SecondLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|center_horizontal">

<LinearLayout
    android:id="@+id/l1"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    app:layout_constraintLeft_toLeftOf="@id/SecondLayout"
    app:layout_constraintTop_toTopOf="@id/SecondLayout"
    app:layout_constraintRight_toRightOf="@id/SecondLayout"
    app:layout_constraintBottom_toBottomOf="@id/l2">

    <TextView
        android:id="@+id/serial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginRight="15dp"
        android:shadowColor="@color/text_shadow"
        android:shadowDy="-1"
        android:shadowRadius="2"
        android:background="@drawable/back1"
        android:fontFamily="@font/open_sans_bold"
        android:paddingLeft="9dp"
        android:paddingTop="2dp"
        android:paddingRight="9dp"
        android:paddingBottom="3dp"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold" />


    <EditText
        android:id="@+id/words"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:background="@drawable/back"
        android:hint="Enter Word"
        android:layout_gravity="center_vertical"
        android:maxWidth="220dp"
        android:autofillHints="name"
        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
        android:inputType="textCapWords"
        android:singleLine="true"
        android:imeOptions="actionDone"
        android:maxLength="25"
        android:paddingLeft="15dp"
        android:paddingTop="3dp"
        android:paddingRight="15dp"
        android:paddingBottom="3dp"
        android:shadowColor="@color/text_shadow"
        android:shadowDy="-1"
        android:shadowRadius="2"
        android:fontFamily="@font/open_sans_bold"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textColorHint="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"/>

</LinearLayout>
            <LinearLayout
                android:id="@+id/l2"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/l1"
                app:layout_constraintLeft_toLeftOf="@id/l1"
                app:layout_constraintRight_toRightOf="@id/l1"
                app:layout_constraintBottom_toTopOf="@id/l3">
    <Button
        android:id="@+id/submit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SUBMIT WORD"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:fontFamily="@font/open_sans_bold"
        android:shadowColor="@color/text_shadow"
        android:shadowDy="-1"
        android:shadowRadius="2"
        android:background="@drawable/back2"
        android:foreground="?attr/selectableItemBackground"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="35sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/reset"
        app:layout_constraintTop_toBottomOf="@id/l1"/>

            <Button
            android:id="@+id/reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:fontFamily="@font/open_sans_bold"
            android:shadowColor="@color/text_shadow"
            android:shadowDy="-1"
            android:shadowRadius="2"
            android:background="@drawable/back2"
            android:foreground="?attr/selectableItemBackground"
            android:layout_marginTop="50dp"
            app:layout_constraintLeft_toRightOf="@id/submit"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/l1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/l3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="20sp"
                app:layout_constraintTop_toBottomOf="@id/l2"
                app:layout_constraintLeft_toLeftOf="@id/l2"
                app:layout_constraintRight_toRightOf="@id/l2"
                app:layout_constraintBottom_toBottomOf="parent">

                <Button
                    android:id="@+id/next"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:fontFamily="@font/open_sans_bold"
                    android:shadowColor="@color/text_shadow"
                    android:shadowDy="-1"
                    android:shadowRadius="2"
                    android:background="@drawable/back2"
                    android:foreground="?attr/selectableItemBackground"
                    app:layout_constraintTop_toBottomOf="@id/l2"
                    app:layout_constraintLeft_toLeftOf="@id/l2"
                    app:layout_constraintRight_toRightOf="@id/l2"/>

                <TextView
                    android:id="@+id/noteText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="10sp"
                    android:textAlignment="center"
                    android:layout_marginTop="10sp"
                    android:text="Note: After entering a word, don't forget to press SUBMIT WORD button."
                    app:layout_constraintTop_toBottomOf="@id/next">
                </TextView>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/Thirdlayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|center_horizontal">

            <Button
                android:id="@+id/startTest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BEGIN TEST"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:fontFamily="@font/open_sans_bold"
                android:shadowColor="@color/text_shadow"
                android:shadowDy="-1"
                android:shadowRadius="2"
                android:background="@drawable/back2"
                android:foreground="?attr/selectableItemBackground"
                app:layout_constraintTop_toTopOf="@id/Thirdlayout"
                app:layout_constraintLeft_toLeftOf="@id/Thirdlayout"
                app:layout_constraintRight_toRightOf="@id/Thirdlayout"
                app:layout_constraintBottom_toBottomOf="@id/Thirdlayout">
            </Button>

            <TextView
                android:id="@+id/text1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="60sp"
                android:textColor="#82CC2D"
                android:textSize="17dp"
                android:visibility="gone"
                android:padding="10sp"
                android:fontFamily="@font/open_sans_bold"
                android:textAlignment="center"
                android:shadowColor="@color/text_shadow"
                android:shadowDy="-1"
                android:shadowRadius="2"
                app:layout_constraintLeft_toLeftOf="@id/startTest"
                app:layout_constraintRight_toRightOf="@id/startTest"
                app:layout_constraintTop_toBottomOf="@id/startTest"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ViewFlipper>
</androidx.constraintlayout.widget.ConstraintLayout>